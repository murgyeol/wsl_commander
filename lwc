#!/bin/bash
# WSL-Windows Commander 실행 및 자동 종료 래퍼 스크립트

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_PID=""

cleanup() {
    if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
        echo -e "\n🛑 WSL Commander 서버(PID: $SERVER_PID)를 종료합니다..."
        kill -SIGTERM "$SERVER_PID" 2>/dev/null || kill -9 "$SERVER_PID" 2>/dev/null
        wait "$SERVER_PID" 2>/dev/null || true
    fi
}

trap cleanup EXIT SIGINT SIGTERM

echo "🚀 WSL Commander 서버가 가동 중입니다 (포트: 8080)..."
echo "💡 터미널에서 Ctrl+C 를 누르면 서버가 함께 종료됩니다."

python3 "$SCRIPT_DIR/wsl_commander.py" "$@" &
SERVER_PID=$!

wait "$SERVER_PID"
